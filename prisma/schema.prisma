generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String              @id @default(cuid())
  name                    String?
  email                   String              @unique
  emailVerified           DateTime?
  hashedPassword          String?
  phone                   String?
  image                   String?
  role                    Role                @default(GUEST)
  twoFactorEnabled        Boolean             @default(false)
  twoFactorSecret         String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  status                  UserStatus          @default(ACTIVE)
  accounts                Account[]
  auditLogs               AuditLog[]
  bookings                Booking[]
  campaignsCreated        Campaign[]          @relation("CampaignsCreated")
  campaignsReceived       CampaignRecipient[] @relation("CampaignsReceived")
  ownerInquiries          Inquiry[]           @relation("OwnerInquiries")
  authoredInquiryMessages InquiryMessage[]    @relation("InquiryMessageAuthor")
  invitations             Invitation[]        @relation("InvitedBy")
  notifications           Notification[]
  properties              Property[]          @relation("OwnerProperties")
  reviews                 Review[]
  sessions                Session[]
  wishlists               Wishlist[]

  @@index([role, status, createdAt])
  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Property {
  id            String          @id @default(cuid())
  title         String
  slug          String          @unique
  description   String
  highlights    String[]
  location      String
  address       String?
  pricePerNight Decimal         @db.Decimal(10, 2)
  maxGuests     Int             @default(2)
  bedrooms      Int             @default(1)
  bathrooms     Int             @default(1)
  amenities     String[]
  rules         String[]
  status        PropertyStatus  @default(DRAFT)
  featured      Boolean         @default(false)
  ownerId       String
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
  blockedDates  BlockedDate[]
  bookings      Booking[]
  owner         User            @relation("OwnerProperties", fields: [ownerId], references: [id], onDelete: Cascade)
  images        PropertyImage[]
  reviews       Review[]
  wishlists     Wishlist[]

  @@index([status])
  @@index([ownerId])
  @@index([slug])
  @@map("properties")
}

model PropertyImage {
  id         String   @id @default(cuid())
  url        String
  publicId   String
  alt        String?
  order      Int      @default(0)
  isPrimary  Boolean  @default(false)
  propertyId String
  createdAt  DateTime @default(now())
  isBanner   Boolean  @default(false)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@map("property_images")
}

model Booking {
  id                 String        @id @default(cuid())
  checkIn            DateTime
  checkOut           DateTime
  guests             Int
  totalPrice         Decimal       @db.Decimal(10, 2)
  status             BookingStatus @default(PENDING)
  notes              String?
  cancellationReason String?
  guestId            String
  propertyId         String
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  bookingCode        String        @unique @default(cuid())
  cancelledAt        DateTime?
  checkedInAt        DateTime?
  checkedOutAt       DateTime?
  confirmedAt        DateTime?
  noShowAt           DateTime?
  guest              User          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  property           Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  review             Review?

  @@index([guestId])
  @@index([propertyId])
  @@index([status])
  @@index([status, createdAt])
  @@index([checkIn, checkOut])
  @@map("bookings")
}

model BlockedDate {
  id         String   @id @default(cuid())
  date       DateTime
  reason     String?
  propertyId String
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, date])
  @@index([propertyId])
  @@map("blocked_dates")
}

model Review {
  id         String        @id @default(cuid())
  rating     Int
  comment    String
  reply      String?
  guestId    String
  propertyId String
  createdAt  DateTime      @default(now())
  updatedAt  DateTime      @updatedAt
  isApproved Boolean       @default(false)
  bookingId  String?       @unique
  status     ReviewStatus  @default(PENDING)
  images     ReviewImage[]
  booking    Booking?      @relation(fields: [bookingId], references: [id])
  guest      User          @relation(fields: [guestId], references: [id], onDelete: Cascade)
  property   Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
  @@index([guestId, propertyId])
  @@index([status])
  @@map("reviews")
}

model ReviewImage {
  id        String   @id @default(cuid())
  url       String
  publicId  String?
  alt       String?
  reviewId  String
  createdAt DateTime @default(now())
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  @@index([reviewId])
  @@map("review_images")
}

model Wishlist {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("wishlists")
}

model Invitation {
  id          String           @id @default(cuid())
  email       String
  role        Role             @default(OWNER)
  token       String           @unique
  status      InvitationStatus @default(PENDING)
  expiresAt   DateTime
  invitedById String
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  invitedBy   User             @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([token])
  @@map("invitations")
}

model Inquiry {
  id              String           @id @default(cuid())
  name            String
  email           String
  phone           String?
  subject         String
  message         String
  status          InquiryStatus    @default(NEW)
  reply           String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  replies         Json?
  adminLastReadAt DateTime?
  guestLastReadAt DateTime?
  lastMessageAt   DateTime         @default(now())
  lastMessageBy   InquirySender    @default(GUEST)
  ownerId         String?
  ownerLastReadAt DateTime?
  source          InquirySource    @default(PUBLIC_CONTACT)
  owner           User?            @relation("OwnerInquiries", fields: [ownerId], references: [id])
  messages        InquiryMessage[]

  @@index([status])
  @@index([status, createdAt])
  @@index([source])
  @@index([ownerId])
  @@index([lastMessageAt])
  @@map("inquiries")
}

model InquiryMessage {
  id        String        @id @default(cuid())
  sender    InquirySender
  body      String
  authorId  String?
  inquiryId String
  createdAt DateTime      @default(now())
  author    User?         @relation("InquiryMessageAuthor", fields: [authorId], references: [id])
  inquiry   Inquiry       @relation(fields: [inquiryId], references: [id], onDelete: Cascade)

  @@index([inquiryId])
  @@index([sender])
  @@index([createdAt])
  @@map("inquiry_messages")
}

model Notification {
  id        String           @id @default(cuid())
  type      NotificationType
  title     String
  body      String
  href      String?
  readAt    DateTime?
  metadata  Json?
  userId    String
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt])
  @@index([type])
  @@index([createdAt])
  @@map("notifications")
}

model AuditLog {
  id        String      @id @default(cuid())
  action    AuditAction
  entity    String
  entityId  String?
  details   Json?
  ipAddress String?
  userId    String?
  createdAt DateTime    @default(now())
  user      User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([action])
  @@index([entity, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

enum Role {
  GUEST
  OWNER
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum PropertyStatus {
  DRAFT
  PENDING
  ACTIVE
  ARCHIVED
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
  CHECKED_IN
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum NotificationType {
  BOOKING
  INQUIRY
  REVIEW
  SYSTEM
}

enum InquirySource {
  PUBLIC_CONTACT
  GUEST_MESSAGE
  OWNER_REQUEST
  ADMIN_DIRECT
}

enum InquirySender {
  GUEST
  OWNER
  ADMIN
  SYSTEM
}

enum ReviewStatus {
  PENDING
  PUBLISHED
  HIDDEN
}

model Campaign {
  id          String              @id @default(cuid())
  name        String
  subject     String
  body        String
  template    String?
  status      CampaignStatus      @default(DRAFT)
  segment     Json
  totalCount  Int                 @default(0)
  sentCount   Int                 @default(0)
  failedCount Int                 @default(0)
  scheduledAt DateTime?
  startedAt   DateTime?
  completedAt DateTime?
  createdById String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  createdBy   User                @relation("CampaignsCreated", fields: [createdById], references: [id])
  recipients  CampaignRecipient[]

  @@index([status])
  @@index([createdAt])
  @@map("campaigns")
}

model CampaignRecipient {
  id         String                  @id @default(cuid())
  campaignId String
  userId     String?
  email      String
  status     CampaignRecipientStatus @default(PENDING)
  sentAt     DateTime?
  failedAt   DateTime?
  errorMsg   String?
  openedAt   DateTime?
  campaign   Campaign                @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User?                   @relation("CampaignsReceived", fields: [userId], references: [id])

  @@unique([campaignId, email])
  @@index([campaignId, status])
  @@index([userId])
  @@map("campaign_recipients")
}

enum CampaignStatus {
  DRAFT
  QUEUED
  SENDING
  PAUSED
  COMPLETED
  FAILED
}

enum CampaignRecipientStatus {
  PENDING
  SENT
  FAILED
  BOUNCED
  OPENED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PASSWORD_CHANGE
  ROLE_CHANGE
  BOOKING_CREATE
  BOOKING_CANCEL
  BOOKING_CONFIRM
  PROPERTY_PUBLISH
  PROPERTY_ARCHIVE
  INVITATION_SEND
  INVITATION_ACCEPT
  BOOKING_CHECK_IN
  BOOKING_CHECK_OUT
  BULK_DELETE
  BULK_UPDATE
  BULK_EMAIL
  CAMPAIGN_SEND
  EXPORT
}
